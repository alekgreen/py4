native def starts_with(value: str, prefix: str) -> bool
native def ends_with(value: str, suffix: str) -> bool
native def find(value: str, needle: str) -> int
native def from_int(value: int) -> str
native def split(value: str, sep: str) -> list[str]
native def replace(value: str, old: str, new: str) -> str
